# Create an OAuth app at https://secure.splitwise.com/oauth_clients
# Set the callback URL to: https://your-server.com/auth/callback
SPLITWISE_CLIENT_ID=your_client_id_here
SPLITWISE_CLIENT_SECRET=your_client_secret_here

# Public base URL of this server (no trailing slash).
# Used as the OAuth issuer URL and to build the Splitwise callback URL.
SERVER_URL=https://your-server.com

# Server bind settings (optional)
HOST=0.0.0.0
PORT=8000
